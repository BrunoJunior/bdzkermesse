{% extends 'modal.html.twig' %}

{% block title %}Activité{% endblock %}

{% block stylesheets %}{{ encore_entry_link_tags('activite_form') }}{% endblock %}

{% block body %}
    {{ form_row(form.nom) }}
    {{ form_row(form.date) }}
    {% if kermesse is not null %}
        {{ form_row(form.accepteTickets) }}
        <div class="well">
            <fieldset>
                <legend class="d-none d-xl-block">Créneaux horaire</legend>
                {{ form_row(form.creneaux) }}
                <button type="button"
                        class="add-another-collection-widget btn btn-secondary"
                        data-list="#activite_creneaux">Ajouter un créneau horaire</button>
            </fieldset>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}{{ encore_entry_script_tags('activite_form') }}{% endblock %}
