{% extends 'base.html.twig' %}
{% block stylesheets %}{{ encore_entry_link_tags('error') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('error') }}{% endblock %}

{% block title %}Kermesses - 404{% endblock %}

{% block body %}
    <div class="card mb-3">
        <div class="row no-gutters">
            <div class="col-md-4">
                <img src="{{ asset('build/images/404.jpg') }}" class="card-img" alt="crying man">
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h2 class="card-title">{{ status_text }}</h2>
                    <p class="card-text">Il semblerait que la page demandée n'existe pas !</p>
                </div>
            </div>
        </div>
    </div>
    <a class="fixed-bottom bg-white-t25"  href="https://www.freepik.com/free-photos-vectors/people">People photo created by luis_molinero - www.freepik.com</a>
{% endblock %}
